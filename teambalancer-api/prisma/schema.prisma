generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite" 
  url      = env("DATABASE_URL")
}

model Tournament {
  id      String  @id @default(uuid())
  name    String
  matches Match[]
}

model Team {
  id          String   @id @default(uuid())
  name        String
  totalSkill  Int
  players     Player[]
  
  matchesAsA  Match[]  @relation("TeamA")
  matchesAsB  Match[]  @relation("TeamB")
}

model Player {
  id              String @id @default(uuid())
  name            String
  skillValue      Int
  skillAdjustment String
  teamId          String
  team            Team   @relation(fields: [teamId], references: [id])
}

model Match {
  id           String     @id @default(uuid())
  date         DateTime   @default(now())
  scoreA       Int
  scoreB       Int
  winner       String
  
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  
  teamAId      String
  teamA        Team       @relation("TeamA", fields: [teamAId], references: [id])
  
  teamBId      String
  teamB        Team       @relation("TeamB", fields: [teamBId], references: [id])
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String // Plain text for this assignment
  
  roleId   String
  role     Role   @relation(fields: [roleId], references: [id])
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique // e.g., 'ADMIN', 'USER'
  
  users       User[]
  permissions Permission[] @relation("RolePermissions") // Many-to-Many relation
}

model Permission {
  id    String @id @default(uuid())
  name  String @unique // e.g., 'CREATE_MATCH', 'DELETE_MATCH', 'SIMULATE'
  
  roles Role[] @relation("RolePermissions")
}